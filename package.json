{
    "name": "figma2scss",
    "displayName": "Figma → SCSS",
    "description": "Transforms selected Figma CSS to project SCSS mixins",
    "version": "1.0.1",
    "publisher": "gregmatys",
    "author": {
        "name": "Greg Matyszewski",
        "email": "grzegorz@huncwot.com"
    },
    "icon": "icon.png",
    "galleryBanner": {
        "color": "#E44F96"
    },
    "pricing": "Free",
    "repository": {
        "type": "git",
        "url": "https://github.com/gregmatys/figma2scss"
    },
    "engines": { "vscode": "^1.60.0" },
    "scripts": {
        "package": "vsce package",
        "publish": "vsce publish"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.9.1"
    },
    "activationEvents": ["onCommand:figma2scss.transform"],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            {
                "command": "figma2scss.transform",
                "title": "Figma → SCSS: Transform selection"
            }
        ],
        "keybindings": [
            {
                "command": "figma2scss.transform",
                "key": "ctrl+shift+g",
                "mac": "cmd+shift+g",
                "when": "editorTextFocus"
            }
        ],
        "configuration": {
            "title": "Figma → SCSS",
            "properties": {
                "figma2scss.fontFamilyMap": {
                    "type": "object",
                    "default": {
                        "display": "display",
                        "text": "text"
                    },
                    "description": "Maps keywords found in Figma font-family names to SCSS mixin tokens. Key = keyword to match (case-insensitive), value = token passed to font-family()."
                }
            }
        }
    }
}
